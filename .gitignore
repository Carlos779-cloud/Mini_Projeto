# ==========================================
# 2. JUPYTER NOTEBOOKS (Metadados e Caches)
# ==========================================
.ipynb_checkpoints
*/.ipynb_checkpoints/*
*.ipynb_checkpoints

# ==========================================
# 3. PYTHON (Arquivos compilados e cache)
# ==========================================
