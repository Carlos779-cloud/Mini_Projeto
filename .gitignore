*.py[cod]
*$py.class
*.so
.Python

# ==========================================
# 4. ARQUIVOS DE DADOS (Segurança e Performance)
# NUNCA suba bases de dados para o GitHub.
# Seu pipeline gera os dados sintéticos localmente.
# ==========================================
data/raw/*.csv
data/raw/*.parquet
data/raw/*.xlsx
data/processed/*.csv
data/processed/*.parquet
*.csv
*.xlsx
*.parquet
*.json
*.sqlite3

